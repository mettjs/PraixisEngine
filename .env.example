# LLM Backend
AI_API_URL=http://localhost:8081      # Base URL of your OpenAI-compatible LLM server
AI_API_KEY=your-llm-api-key          # API key for the LLM server (can be any string for local setups)
MODEL_NAME=gemma3:12b                # Model name as recognized by your LLM server

# Redis
# For a local Redis instance:
REDIS_URL=redis://localhost:6379/0
# For a remote TLS instance (e.g. Upstash):
# REDIS_URL=rediss://default:<password>@<host>:6379

# Session
SESSION_TTL=86400                    # Session expiry in seconds (default: 24 hours)

# Storage
# CHROMA_PATH=/absolute/path/to/chroma_data   # Defaults to chroma_data/ in the project root

# GPU concurrency
# How many LLM calls can run at the same time.
# Set to 1 for a large model on a single GPU. Raise it if your GPU has headroom.
GPU_CONCURRENCY=2

# Admin
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
